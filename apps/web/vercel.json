{
  "regions": ["bom1"],
  "buildCommand": "next build",
  "functions": {
    "app/api/**/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/document-expiry",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/reminder-digest",
      "schedule": "0 4 * * *"
    }
  ]
}
